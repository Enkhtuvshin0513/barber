generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Contact {
  facebook  String?
  instagram String?
  website   String?
}

enum ShopType {
  shop
  barber
}

model BarberShop {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String?
  location   String?
  email      String   @unique
  phone      Int?
  profile    String?
  cover      String?
  contacts   Contact?
  password   String
  type       ShopType?
  categories String[]

  @@map("barber_shop")
}
